// Base set from: https://github.com/tsconfig/bases/blob/main/bases/node22.json
// Ref: https://www.typescriptlang.org/tsconfig
{
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "Node 22",
  
    "compilerOptions": {
      "lib": ["es2023"],                            // Reccomended for Node 22 - lib version in generated JS code (default matches target)
      "module": "NodeNext",                         // Reccomended for Node 22 - what module resolution system to assume when generating JS code
      "target": "ES2023",                           // Reccomended for Node 22 - what flavor of JS to generate natively, newer syntax generates emulated code
      
      "moduleResolution": "NodeNext",               // How tsc tries to find modules, tsc matches nodejs so "NodeNext" is the best choice.

      "strict": true,                               // Reccomended for Node 22
      "esModuleInterop": true,                      // Reccomended for Node 22
      "skipLibCheck": true,                         // Reccomended for Node 22
      "forceConsistentCasingInFileNames": true,     // Reccomended for Node 22

      "sourceMap": true,                            // Generates .map file for debugging
      "outDir": "./build/",                         // write .js and .map files here
      "rootDir": "./src",                           // Prevent an extra /src in the ourDir folder
      "baseUrl": "./",                              // Assume imports are relative to current directory
      "declaration": true,                          // Emit *.d.ts files

      "noImplicitAny": true,                        // Extra checking
      "strictNullChecks": true                      // Extra checking
    },
  "include": [
    "src/*.ts",
    "tests/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
